<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="420.0" prefWidth="720.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">
    <children>
        <HBox spacing="12.0" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="12.0">
            <children>

                <VBox maxWidth="240.0" minWidth="240.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 6; -fx-border-color: #E9ECEF; -fx-border-radius: 6; -fx-padding: 12;">
                    <children>
                        <Label text="Pilotos" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="Nome do Piloto" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtNome" promptText="Ex: Ayrton Senna" style="-fx-background-color: #FFFFFF; -fx-border-color: #CED4DA; -fx-border-radius: 4; -fx-padding: 4; -fx-focus-color: #3498DB; -fx-faint-focus-color: #3498DB22;" />

                                <Label text="Nacionalidade" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtNacionalidade" promptText="Ex: Brasileiro" style="-fx-background-color: #FFFFFF; -fx-border-color: #CED4DA; -fx-border-radius: 4; -fx-padding: 4; -fx-focus-color: #3498DB; -fx-faint-focus-color: #3498DB22;" />

                                <Label text="Equipe" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtEquipe" promptText="Ex: McLaren" style="-fx-background-color: #FFFFFF; -fx-border-color: #CED4DA; -fx-border-radius: 4; -fx-padding: 4; -fx-focus-color: #3498DB; -fx-faint-focus-color: #3498DB22;" />

                                <CheckBox fx:id="cbAtivo" mnemonicParsing="false" text="Piloto Ativo" textFill="#212529">
                                    <font>
                                        <Font size="11.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets top="4.0" />
                                    </VBox.margin>
                                </CheckBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Button fx:id="btnCriar" maxWidth="1.0E30" mnemonicParsing="false" onAction="#btnCriarAction" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6px; -fx-cursor: hand; -fx-focus-color: #27AE60;" text="CRIAR" />
                                <Button fx:id="btnAtualizar" maxWidth="1.0E30" mnemonicParsing="false" onAction="#btnAtualizarAction" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6px; -fx-cursor: hand; -fx-focus-color: #2980B9;" text="ATUALIZAR" />
                                <Button fx:id="btnDeletar" maxWidth="1.0E30" mnemonicParsing="false" onAction="#btnDeletarAction" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6px; -fx-cursor: hand; -fx-focus-color: #C0392B;" text="DELETAR" />
                                <Button fx:id="btnLimpar" maxWidth="1.0E30" mnemonicParsing="false" onAction="#btnLimparAction" style="-fx-background-color: #747D8C; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6px; -fx-cursor: hand; -fx-focus-color: #2F3542;" text="LIMPAR" />
                            </children>
                        </VBox>

                        <Label fx:id="lblMensagem" alignment="CENTER" maxWidth="1.0E30" textAlignment="CENTER" wrapText="true">
                            <font>
                                <Font name="System Bold" size="11.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <TableView fx:id="tblPiloto" onMouseClicked="#carregarCampos" prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-radius: 4;" HBox.hgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" maxWidth="45.0" minWidth="35.0" prefWidth="40.0" text="ID" />
                        <TableColumn fx:id="colNome" prefWidth="80.0" text="Nome" />
                        <TableColumn fx:id="colNacionalidade" prefWidth="140.0" text="Nacionalidade" />
                        <TableColumn fx:id="colEquipe" prefWidth="90.0" text="Equipe" />
                        <TableColumn fx:id="colAtivo" maxWidth="65.0" minWidth="50.0" prefWidth="55.0" text="Ativo" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </HBox>
    </children>
</AnchorPane>